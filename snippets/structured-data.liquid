{% comment %}
  snippets/structured-data.liquid
  JSON-LD Product schema for SEO structured data

  Usage (in layout/theme.liquid within <head>):
    render 'structured-data', product: product

  Validates at: https://search.google.com/test/rich-results
{% endcomment %}

{%- if product -%}
  {%- assign current_variant = product.selected_or_first_available_variant -%}
  {%- assign condition_value = product.metafields.custom.condition.value -%}

  {%- comment -%} Map internal condition to schema.org ItemCondition {%- endcomment -%}
  {%- assign schema_condition = 'https://schema.org/UsedCondition' -%}
  {%- if condition_value == 'Utmärkt' or condition_value == 'Excellent' -%}
    {%- assign schema_condition = 'https://schema.org/UsedCondition' -%}
  {%- endif -%}

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Product",
      "name": {{ product.title | json }},
      "description": {{ product.description | strip_html | truncate: 5000 | json }},
      "url": {{ canonical_url | json }},
      "sku": {{ current_variant.sku | json }},
      "brand": {
        "@type": "Brand",
        "name": {{ product.metafields.custom.brand.value | default: product.vendor | json }}
      },
      "condition": {{ schema_condition | json }},
      {%- if product.featured_media -%}
      "image": [
        {%- for media in product.media limit: 5 -%}
          {{ media | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ],
      {%- endif -%}
      "offers": {
        "@type": "Offer",
        "url": {{ canonical_url | json }},
        "priceCurrency": {{ cart.currency.iso_code | json }},
        "price": {{ current_variant.price | divided_by: 100.0 | json }},
        {%- if current_variant.compare_at_price > current_variant.price -%}
        "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
        {%- endif -%}
        "availability": {% if current_variant.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},
        "seller": {
          "@type": "Organization",
          "name": {{ shop.name | json }}
        }
      }
      {%- if product.metafields.custom.brand != blank
           or product.metafields.custom.year_of_manufacture != blank
           or product.metafields.custom.weight_kg != blank -%}
      ,
      "additionalProperty": [
        {%- if product.metafields.custom.brand != blank -%}
        {
          "@type": "PropertyValue",
          "name": "Märke",
          "value": {{ product.metafields.custom.brand.value | json }}
        }{% unless product.metafields.custom.year_of_manufacture == blank and product.metafields.custom.weight_kg == blank %},{% endunless %}
        {%- endif -%}
        {%- if product.metafields.custom.year_of_manufacture != blank -%}
        {
          "@type": "PropertyValue",
          "name": "Tillverkningsår",
          "value": {{ product.metafields.custom.year_of_manufacture.value | json }}
        }{% unless product.metafields.custom.weight_kg == blank %},{% endunless %}
        {%- endif -%}
        {%- if product.metafields.custom.weight_kg != blank -%}
        {
          "@type": "PropertyValue",
          "name": "Vikt (kg)",
          "value": {{ product.metafields.custom.weight_kg.value | json }}
        }
        {%- endif -%}
      ]
      {%- endif -%}
    }
  </script>
{%- endif -%}
