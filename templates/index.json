          "type": "column",
          "settings": {
            "title": "Klarna & Swish",
            "text": "<p>Betala enkelt med Klarna, Swish eller kort.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "usp_4": {
          "type": "column",
          "settings": {
            "title": "Leverans i hela Sverige",
            "text": "<p>Vi levererar och monterar i hela Sverige. Kontakta oss för offert.<\/p>",
